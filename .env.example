# BDAG GPU Miner configuration
# Copy this file to .env, then edit your wallet before running.

POOL_HOST=62.171.161.32
POOL_PORT=3334

# Replace this with your own 42-character EVM-style wallet address beginning with 0x
WALLET=0x0000000000000000000000000000000000000000

# Optional stratum password. Most pools use x.
PASSWORD=x

# Runtime in seconds. Use 0 for unlimited runtime if supported by future versions.
RUNTIME_SECONDS=9999999999999

# Submission tuning. Conservative defaults for public use.
SUBMIT_MARGIN=1.02
MIN_SUBMIT_THRESHOLD=0.25
EXTRANONCE2_HEX=00000000
